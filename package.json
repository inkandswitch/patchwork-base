{
  "name": "patchwork-base",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Core Patchwork tools, plus a static-HTTP aggregate build.",
  "scripts": {
    "build:static": "node scripts/build-static.mjs",
    "build:static:fresh": "node scripts/build-static.mjs --build",
    "build:tools:ci": "node scripts/build-static.mjs --install",
    "bundle": "node scripts/bundle.mjs",
    "serve:tools": "node scripts/serve-tools.mjs",
    "dev:tools": "pnpm build:static && pnpm serve:tools",
    "dev": "node scripts/serve-tools.mjs --port 2121",
    "deploy:tools": "pnpm build:static && pnpm dlx netlify-cli deploy --dir=static-dist --prod"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
}
