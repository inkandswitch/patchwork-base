{
  "name": "@patchwork/tasks",
  "version": "0.0.3",
  "description": "Task-Related Datatypes and Tools",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "push": "pushwork sync",
    "watch": "nodemon --watch src -e js,tsx,ts,tsx,css,json --exec 'pnpm build && pnpm push'",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [],
  "author": "Ink & Switch",
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@automerge/automerge-repo": "2.6.0-subduction.20",
    "@automerge/automerge-repo-react-hooks": "2.6.0-subduction.20",
    "@automerge/vanillajs": "2.6.0-subduction.20",
    "@awarth/tasklib": "^0.0.10",
    "@inkandswitch/patchwork-bootloader": "^0.0.9",
    "@inkandswitch/patchwork-elements": "^0.0.3",
    "@inkandswitch/patchwork-plugins": "^0.0.2",
    "boring-name-generator": "^1.0.3",
    "es-module-shims": "^2.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.1.14",
    "vite": "^5.4.21",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
